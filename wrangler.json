{
  "$schema": "https://unpkg.com/wrangler@latest/config-schema.json",
  "name": "uithub-simple",
  "account_id": "080fd9e0587416d2fa30ed1f527e2323",
  "compatibility_date": "2025-11-30",
  "main": "worker.ts",
  "assets": { "directory": "./" },
  "kv_namespaces": [
    { "binding": "KV", "id": "698c335bd4e343089a51846f803c75e0" }
  ],
  "env": {
    "prod": {
      "routes": [
        { "custom_domain": true, "pattern": "uithub.com" },
        { "custom_domain": true, "pattern": "www.uithub.com" }
      ],
      "kv_namespaces": [
        { "binding": "KV", "id": "698c335bd4e343089a51846f803c75e0" }
      ]
    }
  }
}
