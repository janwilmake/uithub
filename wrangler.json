{
  "$schema": "https://unpkg.com/wrangler@latest/config-schema.json",
  "name": "uithub-simple",
  "account_id": "080fd9e0587416d2fa30ed1f527e2323",
  "compatibility_date": "2026-01-24",
  "main": "website/index.ts",
  "assets": { "directory": "./public" },
  "kv_namespaces": [
    { "binding": "KV", "id": "698c335bd4e343089a51846f803c75e0" }
  ],
  "durable_objects": {
    "bindings": [
      { "name": "ANALYTICS_DO", "class_name": "AnalyticsDO" },
      { "name": "SOCIALS_DO", "class_name": "SocialsDO" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["AnalyticsDO"] },
    { "tag": "v2", "new_sqlite_classes": ["SocialsDO"] },
    { "tag": "v3", "new_sqlite_classes": ["FileDO"] },
    { "tag": "v4", "deleted_classes": ["FileDO"] }
  ],
  "env": {
    "prod": {
      "routes": [
        { "custom_domain": true, "pattern": "uithub.com" },
        { "custom_domain": true, "pattern": "www.uithub.com" }
      ],
      "kv_namespaces": [
        { "binding": "KV", "id": "698c335bd4e343089a51846f803c75e0" }
      ],
      "durable_objects": {
        "bindings": [
          { "name": "ANALYTICS_DO", "class_name": "AnalyticsDO" },
          { "name": "SOCIALS_DO", "class_name": "SocialsDO" }
        ]
      },
      "migrations": [
        { "tag": "v1", "new_sqlite_classes": ["AnalyticsDO"] },
        { "tag": "v2", "new_sqlite_classes": ["SocialsDO"] },
        { "tag": "v3", "new_sqlite_classes": ["FileDO"] },
        { "tag": "v4", "deleted_classes": ["FileDO"] }
      ]
    }
  }
}
